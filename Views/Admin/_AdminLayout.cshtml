@{
    string currentAction = ViewContext.RouteData.Values["action"].ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — @ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f8f8f8;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: #1a1a1a;
            position: fixed;
            top: 0;
            left: 0;
            padding: 24px 0;
        }

        .sidebar-brand {
            color: #fff;
            font-weight: 700;
            font-size: 1.2rem;
            padding: 0 24px 24px;
            border-bottom: 1px solid #333;
            display: block;
            text-decoration: none;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #aaa;
            text-decoration: none;
            padding: 11px 24px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

            .sidebar-link:hover, .sidebar-link.active {
                color: #fff;
                background: #2a2a2a;
            }

            .sidebar-link i {
                font-size: 1rem;
                width: 18px;
            }

        .main-content {
            margin-left: 220px;
            padding: 32px;
        }

        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px 24px;
            border: 1px solid #f0f0f0;
        }

            .stat-card .label {
                font-size: 0.8rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .stat-card .value {
                font-size: 1.8rem;
                font-weight: 700;
                margin-top: 4px;
            }

        .admin-table {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #f0f0f0;
        }

            .admin-table table {
                margin: 0;
            }

            .admin-table th {
                background: #fafafa;
                font-size: 0.8rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.4px;
                color: #888;
                border-bottom: 1px solid #f0f0f0;
                padding: 12px 16px;
            }

            .admin-table td {
                padding: 14px 16px;
                font-size: 0.9rem;
                vertical-align: middle;
                border-bottom: 1px solid #f8f8f8;
            }

        .badge-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a class="sidebar-brand" href="@Url.Action("Index","Admin")">⚡ ShopEase</a>
        <div class="mt-3">
            <a href="@Url.Action("Index","Admin")"
               class="sidebar-link @(currentAction == "Index" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a href="@Url.Action("Products","Admin")"
               class="sidebar-link @(currentAction == "Products" || currentAction == "CreateProduct" || currentAction == "EditProduct" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Products
            </a>
            <a href="@Url.Action("Orders","Admin")"
               class="sidebar-link @(currentAction == "Orders" ? "active" : "")">
                <i class="bi bi-receipt"></i> Orders
            </a>
            <a href="@Url.Action("Categories","Admin")"
               class="sidebar-link @(currentAction == "Categories" ? "active" : "")">
                <i class="bi bi-tags"></i> Categories
            </a>
            <hr style="border-color:#333; margin: 16px 0;" />
            <a href="@Url.Action("Index","Home")" class="sidebar-link">
                <i class="bi bi-arrow-left"></i> Back to Store
            </a>
            <a href="@Url.Action("Logout","Account")" class="sidebar-link">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </div>

    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success py-2 mb-3" style="font-size:0.88rem; border-radius:10px;">
                @TempData["Success"]
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)C:\Users\princ\source\repos\ShopEase
</body>
</html>
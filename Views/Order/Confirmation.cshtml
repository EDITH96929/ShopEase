@model ShopEase.Models.Order
@{ ViewBag.Title = "Order Confirmed"; }

<div class="container my-5" style="max-width:600px;">
    <!-- Success header -->
    <div class="text-center mb-5">
        <div style="width:64px; height:64px; background:#f0faf0; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
            <i class="bi bi-check-lg" style="font-size:1.8rem; color:#2e7d32;"></i>
        </div>
        <h4 class="fw-bold">Order Placed!</h4>
        <p class="text-muted">Thank you for your order. We'll get it shipped soon.</p>
        <span style="background:#f5f5f5; padding:6px 16px; border-radius:20px; font-size:0.88rem;">
            Order #@Model.OrderID
        </span>
    </div>

    <!-- Order details -->
    <div class="p-4 mb-4" style="border:1px solid #f0f0f0; border-radius:16px;">
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted" style="font-size:0.88rem;">Status</span>
            <span class="badge" style="background:#fff3e0; color:#e65100; border-radius:20px; padding:4px 12px; font-size:0.8rem;">
                @Model.Status
            </span>
        </div>
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted" style="font-size:0.88rem;">Date</span>
            <span style="font-size:0.88rem;">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
        </div>
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted" style="font-size:0.88rem;">Ship to</span>
            <span style="font-size:0.88rem; text-align:right; max-width:60%;">@Model.ShipAddress</span>
        </div>
        <hr style="border-color:#f0f0f0;" />
        <div class="d-flex justify-content-between fw-bold">
            <span>Total Paid</span>
            <span>$@Model.TotalAmount.ToString("0.00")</span>
        </div>
    </div>

    <!-- Items -->
    @if (Model.Items != null)
    {
        <h6 class="fw-bold mb-3">Items Ordered</h6>
        foreach (var item in Model.Items)
        {
            <div class="d-flex align-items-center gap-3 mb-3 p-3"
                 style="border:1px solid #f5f5f5; border-radius:12px;">
                <img src="@item.ImageURL" style="width:56px; height:56px; object-fit:cover; border-radius:8px; background:#f5f5f5;" />
                <div class="flex-grow-1">
                    <div class="fw-semibold" style="font-size:0.92rem;">@item.ProductName</div>
                    <div class="text-muted" style="font-size:0.8rem;">Qty: @item.Quantity × $@item.UnitPrice.ToString("0.00")</div>
                </div>
                <div class="fw-bold">$@((item.Quantity * item.UnitPrice).ToString("0.00"))</div>
            </div>
        }
    }

    <div class="d-flex gap-2 mt-4">
        <a href="@Url.Action("History","Order")" class="btn btn-dark px-4">View Orders</a>
        <a href="@Url.Action("Index","Product")" class="btn btn-outline-dark px-4">Continue Shopping</a>
    </div>
</div>
@using System.Linq
@model ShopEase.Models.ViewModels.CheckoutViewModel
@{ ViewBag.Title = "Checkout"; }

<div class="container my-5">
    <h4 class="fw-bold mb-4">Checkout</h4>

    <div class="row g-4">
        <!-- Shipping form -->
        <div class="col-md-7">
            <div class="p-4" style="border:1px solid #f0f0f0; border-radius:16px;">
                <h6 class="fw-bold mb-3">Shipping Details</h6>

                @using (Html.BeginForm("Checkout", "Order", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        @Html.LabelFor(m => m.FullName, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
                        @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", placeholder = "Full name" })
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Phone, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "Phone number" })
                        @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Address, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
                        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", placeholder = "Street address", rows = "2" })
                        @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(m => m.City, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
                        @Html.TextBoxFor(m => m.City, new { @class = "form-control", placeholder = "City" })
                        @Html.ValidationMessageFor(m => m.City, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger", style = "font-size:0.85rem;" })

                    <button type="submit" class="btn btn-dark w-100 py-2">
                        Place Order — $@Model.Total.ToString("0.00")
                    </button>
                }
            </div>
        </div>

        <!-- Order summary -->
        <div class="col-md-5">
            <div class="p-4" style="background:#f9f9f9; border-radius:16px;">
                <h6 class="fw-bold mb-3">Order Summary</h6>

                @if (Model.CartItems != null)
                {
                    foreach (var item in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <img src="@item.ImageURL" style="width:44px; height:44px; object-fit:cover; border-radius:6px; background:#eee;" />
                                <div>
                                    <div style="font-size:0.88rem; font-weight:600;">@item.ProductName</div>
                                    <div style="font-size:0.78rem; color:#888;">Qty: @item.Quantity</div>
                                </div>
                            </div>
                            <div style="font-weight:600; font-size:0.9rem;">
                                $@((item.Price * item.Quantity).ToString("0.00"))
                            </div>
                        </div>
                    }
                }

                <hr style="border-color:#e8e8e8;" />
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span>$@Model.Total.ToString("0.00")</span>
                </div>
            </div>
        </div>
    </div>
</div>
@using System.Collections.Generic
@model List<ShopEase.Models.Order>
@{ ViewBag.Title = "My Orders"; }

<div class="container my-5">
    <h4 class="fw-bold mb-4">My Orders</h4>

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p>You haven't placed any orders yet.</p>
            <a href="@Url.Action("Index","Product")" class="btn btn-dark mt-2">Start Shopping</a>
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            <div class="p-4 mb-3" style="border:1px solid #f0f0f0; border-radius:16px;">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <div class="fw-bold">Order #@order.OrderID</div>
                        <div class="text-muted" style="font-size:0.85rem;">
                            @order.CreatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                    <div class="text-end">
                        @{
                            string badgeBg = order.Status == "Delivered" ? "#e8f5e9" :
                                             order.Status == "Shipped" ? "#e3f2fd" :
                                             order.Status == "Cancelled" ? "#ffebee" : "#fff3e0";
                            string badgeColor = order.Status == "Delivered" ? "#2e7d32" :
                                                order.Status == "Shipped" ? "#1565c0" :
                                                order.Status == "Cancelled" ? "#c62828" : "#e65100";
                        }
                        <span style="background:@badgeBg; color:@badgeColor; padding:4px 14px; border-radius:20px; font-size:0.8rem;">
                            @order.Status
                        </span>
                        <div class="fw-bold mt-1">$@order.TotalAmount.ToString("0.00")</div>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="@Url.Action("Detail", "Order", new { id = order.OrderID })"
                       class="btn btn-outline-dark btn-sm">View Details</a>
                </div>
            </div>
        }
    }
</div>
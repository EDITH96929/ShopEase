@{
    int cartCount = 0;
    if (Session["UserID"] != null)
    {
        try
        {
            var cartRepo = new ShopEase.DAL.CartRepository();
            cartCount = cartRepo.GetCartCount((int)Session["UserID"]);
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — ShopEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #fff;
            color: #1a1a1a;
        }

        .navbar {
            border-bottom: 1px solid #f0f0f0;
            padding: 14px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
            color: #1a1a1a !important;
        }

        .nav-link {
            color: #555 !important;
            font-size: 0.9rem;
            margin: 0 4px;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: #1a1a1a !important;
            }

        .cart-badge {
            background: #1a1a1a;
            color: #fff;
            border-radius: 50%;
            padding: 1px 6px;
            font-size: 0.7rem;
            margin-left: 2px;
        }

        .product-card {
            border: 1px solid #f0f0f0;
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .product-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.08);
            }

            .product-card img {
                width: 100%;
                height: 220px;
                object-fit: cover;
                background: #f8f8f8;
            }

            .product-card .card-body {
                padding: 16px;
            }

            .product-card .price {
                font-weight: 700;
                font-size: 1.1rem;
            }

            .product-card .category-badge {
                font-size: 0.72rem;
                background: #f5f5f5;
                color: #666;
                padding: 3px 8px;
                border-radius: 20px;
            }

        .btn-dark {
            background: #1a1a1a;
            border: none;
            border-radius: 8px;
        }

            .btn-dark:hover {
                background: #333;
            }

        .btn-outline-dark {
            border-radius: 8px;
        }

        footer {
            border-top: 1px solid #f0f0f0;
            margin-top: 60px;
            padding: 30px 0;
            color: #999;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index","Home")">ShopEase</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index","Home")">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index","Product")">Products</a></li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (Session["UserID"] != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Cart")">
                                <i class="bi bi-bag"></i> Cart
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("History","Order")">Orders</a>
                        </li>
                        if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" href="@Url.Action("Index","Admin")">Admin</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Logout","Account")">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login","Account")">Login</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-dark btn-sm px-3" href="@Url.Action("Register","Account")">Sign Up</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year ShopEase. Built with ASP.NET MVC.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
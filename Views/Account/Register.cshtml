@model ShopEase.Models.ViewModels.RegisterViewModel
@{ ViewBag.Title = "Create Account"; }

<div class="container my-5" style="max-width:480px;">
    <h3 class="fw-bold mb-1">Create account</h3>
    <p class="text-muted mb-4" style="font-size:0.9rem;">Join ShopEase today</p>

    @using (Html.BeginForm("Register", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            @Html.LabelFor(m => m.FullName, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", placeholder = "Your Full Name" })
            @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "you@example.com" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Min. 6 characters" })
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.ConfirmPassword, "Confirm Password", new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Repeat password" })
            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger", style = "font-size:0.8rem;" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Phone, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "Optional" })
        </div>

        <div class="mb-4">
            @Html.LabelFor(m => m.Address, new { @class = "form-label fw-semibold", style = "font-size:0.88rem;" })
            @Html.TextAreaFor(m => m.Address, new { @class = "form-control", placeholder = "Your delivery address", rows = "2" })
        </div>

        <button type="submit" class="btn btn-dark w-100 py-2">Create Account</button>
    }

    <p class="text-center text-muted mt-4" style="font-size:0.88rem;">
        Already have an account? <a href="@Url.Action("Login")" class="text-dark fw-semibold">Sign in</a>
    </p>
</div>